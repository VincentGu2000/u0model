# Environment Path Configuration
# ================================
# Copy this file to .env and fill in your actual paths:
#   cp .env.example .env
#
# Then source it before running commands:
#   source .env

# Model directory - for pretrained weights and fine-tuned outputs
# Examples: /data/model, /home/user/models, etc.
MODEL_BASE_DIR=/path/to/your/models

# Dataset directory - for training and evaluation datasets
# Examples: /data/datasets, /home/user/data, etc.
DATA_BASE_DIR=/path/to/your/datasets

# Project root directory (defaults to current directory)
PROJECT_DIR=.

# ROS workspace path (only needed for deployment with ROS)
ROS_WS_DIR=/path/to/your/ros_ws
